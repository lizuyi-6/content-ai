# ========== AI 供应商配置 ==========

# 选择 AI 供应商：qwen | glm | openai | deepseek | ollama | custom
# 推荐中文使用：qwen（通义千问）或 glm（智谱 AI）
AI_PROVIDER=qwen

# --- Qwen 通义千问配置（推荐中文） ---
QWEN_API_KEY=sk-your-qwen-api-key-here
QWEN_MODEL=qwen-plus

# --- GLM 智谱 AI 配置（推荐中文） ---
GLM_API_KEY=sk-your-glm-api-key-here
GLM_MODEL=glm-4

# --- OpenAI 配置 ---
# OPENAI_API_KEY=sk-your-api-key-here
# OPENAI_MODEL=gpt-4o-mini

# --- DeepSeek 配置 ---
# DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_MODEL=deepseek-chat

# --- Ollama 配置（本地部署） ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# --- 自定义供应商配置 ---
# CUSTOM_API_URL=https://your-custom-api.com/v1/chat
# CUSTOM_API_KEY=your-custom-api-key
# CUSTOM_MODEL=your-model-name

# ========== 服务器配置 ==========
PORT=3000
NODE_ENV=development
